FROM python:3.11

WORKDIR /workspace

# Copy the entire LangChain repository
COPY . /workspace

# Install langchain-core from source
RUN pip install -e libs/core

# Install langchain from source
RUN pip install -e libs/langchain

# Install langchain-community from source
RUN pip install -e libs/community

# Install langchain-redis from source
RUN pip install -e libs/partners/redis

# Install Jupyter and other dependencies
RUN pip install jupyter redis sentence-transformers

# Expose Jupyter port
EXPOSE 8888

# Set a default Redis URL
ENV REDIS_URL_DOCKER=redis://redis:6379

# Start Jupyter Notebook
CMD ["jupyter", "notebook", "--ip=0.0.0.0", "--port=8888", "--no-browser", "--allow-root", "--notebook-dir=/workspace/libs/partners/redis/docs"]